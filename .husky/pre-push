# Only run checks if there are commits to push
branch="$(git rev-parse --abbrev-ref HEAD)"
upstream="origin/$branch"
if [ "$(git rev-list $upstream..HEAD)" = "" ]; then
  echo "==Husky Status:========"
  echo "No new commits to push. Skipping pre-push checks."
  echo "==Git Status:=========="
  exit 0
fi

echo "🚀 Running pre-push checks..."

# Run the full CI suite locally
echo "📋 Running full CI checks..."
npm run check-all

# Run Cypress tests (quick smoke test)
echo "🧪 Running Cypress tests..."
npm run cy:run

echo "✅ Pre-push checks passed! Ready to push." 