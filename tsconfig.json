{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["DOM", "ES2021"],
    "sourceMap": true,
    "types": ["cypress", "node"],
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true
  },
  "include": ["cypress/**/*.ts", "cypress/**/*.tsx", "cypress.config.ts"],
  "exclude": ["node_modules"]
}
